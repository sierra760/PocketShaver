# Object files
*.o

# Backups
*~

# Mac OS X metadata
*.DS_Store

#
# Xcode gitignore settings are from https://github.com/github/gitignore/blob/master/Global/Xcode.gitignore
#

## Xcode, Build generated
build/
DerivedData/

## Xcode, Various settings
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
# Ignore user-local xcschemes but keep shared ones (xcshareddata/xcschemes/*)
xcschemes/*
!xcshareddata/xcschemes/**
project.xcworkspace/

resources/
# Phase 3 Plan 03-02 exception: PocketShaverTests/Resources/ is an Xcode
# test group for gfxaccel_resources lifecycle + zero-copy tests. The bare
# `resources/` rule above matches case-insensitively on macOS and would
# otherwise swallow this intentional path.
!SheepShaver/src/MacOSX/PocketShaverTests/Resources/
!SheepShaver/src/MacOSX/PocketShaverTests/Resources/**
loggo.txt

## Xcode, Other
*.moved-aside
*.xccheckout
*.xcscmblueprint

